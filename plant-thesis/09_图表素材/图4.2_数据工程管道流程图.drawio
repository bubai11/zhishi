        <mxCell id="raw-stage" value="原始数据暂存&#xa;CSV / Excel / JSON / 图片链接 / 边界数据" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=14;fontFamily=SimSun" vertex="1" parent="1">
          <mxGeometry x="365" y="135" width="220" height="62" as="geometry" />
        </mxCell>
        <mxCell id="clean-stage" value="数据清洗与标准化&#xa;字段统一、缺失值处理、重复记录处理、名称规范化" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=14;fontFamily=SimSun" vertex="1" parent="1">
