        <mxCell id="merge-stage" value="数据融合与关联&#xa;分类信息、保护等级、分布区域、保护地信息" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=14;fontFamily=SimSun" vertex="1" parent="1">
