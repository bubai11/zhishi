{
  "name": "plant-knowledge-backend",
  "version": "1.0.0",
  "description": "植物科普学习与知识可视化系统后端",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "test": "node --require ./tests/setup.js --test",
    "db:ensure-indexes": "node scripts/ensure-performance-indexes.js",
    "migrate:redlist-alert-user-state": "node scripts/migrate-redlist-alert-user-state.js",
    "migrate:chinese-names": "node scripts/migrate-chinese-name-infra.js",
    "migrate:frontend-fields": "node scripts/migrate-frontend-fields.js",
    "migrate:iplant-enrichment": "node scripts/migrate-iplant-enrichment-infra.js",
    "cn:update": "node scripts/batch-update-chinese-names.js",
    "iplant:enrich": "node scripts/enrich-plants-from-iplant.js",
    "human-review:export": "node scripts/export-human-review-queue.js",
    "cn:review-high:prepare": "node scripts/high-priority-manual-pipeline.js prepare",
    "cn:review-high:merge": "node scripts/high-priority-manual-pipeline.js merge",
    "cn:review-hybrid:prepare": "node scripts/high-priority-manual-pipeline.js prepare --mode=hybrid --limit=1797",
    "cn:review-hybrid:init": "node scripts/init-hybrid-chinese-names.js",
    "cn:review-hybrid:auto-fill": "node scripts/auto-fill-hybrid-chinese-names.js",
    "cn:review-hybrid:import-direct": "node scripts/import-hybrid-review-direct.js",
