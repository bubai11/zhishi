    "import:iucn": "node scripts/import-iucn-redlist.js",
    "import:wdpa": "node scripts/import-wdpa.js",
    "data:import": "node scripts/import-maintenance-data.js",
    "data:import:wgsrpd-map": "node scripts/import-wgsrpd-region-country-map.js",
